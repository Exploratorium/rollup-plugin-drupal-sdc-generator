    "prettier": "prettier .",
    "prettier:fix": "prettier --write .",
    "test": "NODE_OPTIONS=\"$NODE_OPTIONS --experimental-vm-modules\" jest --config jest.config.cjs",
    "eject": "sh -c 'mkdir -p \"${1:-$INIT_CWD}\" && cp -r templates/. \"${1:-$INIT_CWD}\"' --"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
